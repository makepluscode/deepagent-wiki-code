# 필수
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# When both GOOGLE_API_KEY and ANTHROPIC_API_KEY are set: which provider to use first (anthropic|claude or google|gemini). Empty = Google first.
# DEEPAGENT_LLM_PRIMARY=anthropic

# DeepAgent examples: optional Anthropic model (prepend anthropic: if value has no colon). Default in 31-deepagent-helloworld is Haiku 4.5.
# DEEPAGENT_ANTHROPIC_MODEL=claude-haiku-4-5
# DEEPAGENT_ANTHROPIC_MODEL=anthropic:claude-sonnet-4-6

# 31번 예제: 1이면 API 없이 mock만 (키가 없을 때도 자동 mock)
DEEPAGENT_EXAMPLE_MOCK=0

# 선택 (일부 예제에서 사용)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (example 31: if set, used before Anthropic; AI Studio key is usually GOOGLE_API_KEY)
GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# LangSmith tracing (optional; examples 38-39)
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=deepagent-wiki-code
